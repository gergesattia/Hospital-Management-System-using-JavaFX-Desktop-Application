<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReceptionistPrescriptionsController" style="-fx-background-color: #EEEEEE;">
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 15 30; -fx-alignment: CENTER_LEFT; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4); -fx-border-color: #D1D1D1; -fx-border-width: 0 0 1 0;">
            <Label text="Reception - Prescriptions" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Sign Out" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #548CA8; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: #548CA8; -fx-border-width: 1.5; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>
    <left>
        <VBox style="-fx-background-color: #334257; -fx-padding: 30 15; -fx-spacing: 12; -fx-pref-width: 260;">
            <Label text="MEDICORE" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800; -fx-padding: 0 0 20 5;"/>
            <Button text="📝  Registration" onAction="#showManagePatients" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="📋  Prescriptions" onAction="#showPrescriptions" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-background-radius: 4; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <HBox style="-fx-padding: 30;" spacing="30">
            <!-- Left Side: Table View -->
            <VBox HBox.hgrow="ALWAYS" spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="All Prescriptions" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <TextField fx:id="searchField" promptText="Search patient or medicine..." prefWidth="250" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8;"/>
                    <Button text="🔄" onAction="#loadData" style="-fx-background-color: transparent; -fx-border-color: #548CA8; -fx-text-fill: #548CA8; -fx-padding: 5 10; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
                <TableView fx:id="prescriptionsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="idCol" text="Ref #" prefWidth="70"/>
                        <TableColumn fx:id="patientCol" text="Patient Name" prefWidth="200"/>
                        <TableColumn fx:id="medicineCol" text="Medicine" prefWidth="150"/>
                        <TableColumn fx:id="dateCol" text="Date Issued" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- Right Side: Printable View -->
            <VBox spacing="20" minWidth="350" maxWidth="350" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                <Label text="Prescription Preview" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;"/>
                <TextArea fx:id="documentArea" VBox.vgrow="ALWAYS" wrapText="true" editable="false"
                          style="-fx-font-family: 'Consolas', 'Courier New'; -fx-background-color: #F8F9FE; -fx-font-size: 13px; -fx-control-inner-background: #F8F9FE; -fx-border-color: #EDF2F7; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10;"/>
                <VBox spacing="10">
                    <Button text="Print Prescription" onAction="#handlePrint" maxWidth="Infinity" style="-fx-background-color: #548CA8; -fx-text-fill: white; -fx-font-weight: 800; -fx-padding: 15; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    <Button text="Email to Patient" maxWidth="Infinity" style="-fx-background-color: white; -fx-text-fill: #476072; -fx-border-color: #D1D1D1; -fx-border-width: 1.5; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: 600;"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>


