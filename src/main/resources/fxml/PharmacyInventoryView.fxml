<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PharmacyInventoryController" style="-fx-background-color: #EEEEEE;">
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 15 30; -fx-alignment: CENTER_LEFT; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4); -fx-border-color: #D1D1D1; -fx-border-width: 0 0 1 0;">
            <Label text="Medicine Inventory" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Sign Out" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #548CA8; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: #548CA8; -fx-border-width: 1.5; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>
    <left>
        <VBox style="-fx-background-color: #334257; -fx-padding: 30 15; -fx-spacing: 12; -fx-pref-width: 260;">
            <Label text="MEDICORE" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800; -fx-padding: 0 0 20 5;"/>
            <Button text="💊  Prescriptions" onAction="#showPrescriptions" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="📦  Inventory" onAction="#showInventory" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="💰  POS" onAction="#showPos" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="📊  Sales History" onAction="#showSales" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="🏭  Suppliers" onAction="#showSuppliers" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <HBox style="-fx-padding: 30;" spacing="30">

            <!-- Left: Medicines Table -->
            <VBox HBox.hgrow="ALWAYS" spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Medicine Stock" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <TextField fx:id="searchField" promptText="Search name or supplier..." prefWidth="250" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8;"/>
                    <Button text="🔄" onAction="#loadMedicines" style="-fx-background-color: transparent; -fx-border-color: #548CA8; -fx-text-fill: #548CA8; -fx-padding: 5 10; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="medicinesTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="nameCol" text="Medicine Name" prefWidth="200"/>
                        <TableColumn fx:id="qtyCol" text="Qty" prefWidth="70"/>
                        <TableColumn fx:id="priceCol" text="Unit Price" prefWidth="100"/>
                        <TableColumn fx:id="supplierCol" text="Supplier" prefWidth="160"/>
                        <TableColumn fx:id="expiryCol" text="Expiry Date" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- Right: Form -->
            <VBox spacing="20" minWidth="380" maxWidth="380" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                <Label text="Medicine Details" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;"/>

                <VBox spacing="15" VBox.vgrow="ALWAYS">
                    <VBox spacing="5">
                        <Label text="Medicine Name" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                        <TextField fx:id="nameField" promptText="e.g. Paracetamol 500mg" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                    </VBox>
                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Quantity" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="quantityField" promptText="0" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="5">
                        <Label text="Unit Price (EGP)" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                        <TextField fx:id="priceField" promptText="0.00" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Supplier" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                        <TextField fx:id="supplierField" promptText="Supplier name" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Expiry Date" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                        <DatePicker fx:id="expiryPicker" maxWidth="Infinity" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;"/>
                    </VBox>
                </VBox>

                <VBox spacing="10">
                    <HBox spacing="10">
                        <Button text="Add Medicine" onAction="#handleAdd" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #548CA8; -fx-text-fill: white; -fx-font-weight: 800; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;"/>
                        <Button text="Update" onAction="#handleUpdate" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-text-fill: #548CA8; -fx-border-color: #548CA8; -fx-border-width: 1.5; -fx-padding: 10; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: 700;"/>
                    </HBox>
                    <Button text="Delete Medicine" onAction="#handleDelete" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #E71D36; -fx-border-color: #E71D36; -fx-border-width: 1.5; -fx-padding: 10; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: 700;"/>
                </VBox>
            </VBox>

        </HBox>
    </center>
</BorderPane>
