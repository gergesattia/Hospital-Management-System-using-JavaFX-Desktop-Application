<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PharmacySalesController" style="-fx-background-color: #F4F7F6;">
    
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 15 30; -fx-alignment: CENTER_LEFT; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4); -fx-border-color: #D1D1D1; -fx-border-width: 0 0 1 0;">
            <Label text="Sales History &amp; Analytics" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Sign Out" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #548CA8; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: #548CA8; -fx-border-width: 1.5; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox style="-fx-background-color: #334257; -fx-padding: 30 15; -fx-spacing: 12; -fx-pref-width: 260;">
            <Label text="MEDICORE" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800; -fx-padding: 0 0 20 5;"/>
            <Button text="💊  Prescriptions" onAction="#showPrescriptions" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="📦  Inventory" onAction="#showInventory" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="💰  POS" onAction="#showPos" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="📊  Sales" onAction="#showSales" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="🏭  Suppliers" onAction="#showSuppliers" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="25" style="-fx-padding: 25;">
            
            <!-- Stats Cards -->
            <HBox spacing="20">
                <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                    <Label text="Today's Revenue" style="-fx-text-fill: #6C757D; -fx-font-weight: 600;"/>
                    <Label fx:id="dailyRevenueLabel" text="\$0.00" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #334257;"/>
                </VBox>
                <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                    <Label text="Today's Profit" style="-fx-text-fill: #6C757D; -fx-font-weight: 600;"/>
                    <Label fx:id="dailyProfitLabel" text="\$0.00" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #2A9D8F;"/>
                </VBox>
                <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                    <Label text="Monthly Revenue" style="-fx-text-fill: #6C757D; -fx-font-weight: 600;"/>
                    <Label fx:id="monthlyRevenueLabel" text="\$0.00" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #548CA8;"/>
                </VBox>
            </HBox>

            <!-- Sales Table -->
            <VBox VBox.vgrow="ALWAYS" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Transaction Log" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" promptText="Search by patient..." style="-fx-pref-width: 250; -fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8;"/>
                </HBox>
                
                <TableView fx:id="salesTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="patientCol" text="Patient Name" prefWidth="200"/>
                        <TableColumn fx:id="totalCol" text="Total" prefWidth="100"/>
                        <TableColumn fx:id="methodCol" text="Method" prefWidth="100"/>
                        <TableColumn fx:id="dateCol" text="Date &amp; Time" prefWidth="180"/>
                        <TableColumn fx:id="pharmacistCol" text="Pharmacist" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
