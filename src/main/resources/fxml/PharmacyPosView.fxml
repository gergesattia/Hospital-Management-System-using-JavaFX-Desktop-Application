<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PharmacyPosController" style="-fx-background-color: #F4F7F6;">
    
    <!-- Top Header -->
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 15 30; -fx-alignment: CENTER_LEFT; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4); -fx-border-color: #D1D1D1; -fx-border-width: 0 0 1 0;">
            <VBox spacing="2">
                <Label text="Pharmacy POS" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #334257;"/>
                <Label fx:id="dateLabel" text="Date" style="-fx-text-fill: #6C757D; -fx-font-size: 13px;"/>
            </VBox>
            <HBox spacing="15" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                <Button text="Sign Out" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #548CA8; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: #548CA8; -fx-border-width: 1.5; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox style="-fx-background-color: #334257; -fx-padding: 30 15; -fx-spacing: 12; -fx-pref-width: 260;">
            <Label text="MEDICORE" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800; -fx-padding: 0 0 20 5;"/>
            <Button text="💊  Prescriptions" onAction="#showPrescriptions" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="📦  Inventory" onAction="#showInventory" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="💰  POS" onAction="#showPos" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="📊  Sales" onAction="#showSales" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="🏭  Suppliers" onAction="#showSuppliers" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <center>
        <HBox spacing="25" style="-fx-padding: 25;">
            
            <!-- Left Side: Product Selection -->
            <VBox HBox.hgrow="ALWAYS" spacing="20">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4);">
                    <TextField fx:id="searchField" promptText="Search medicine by name or description..." HBox.hgrow="ALWAYS" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;"/>
                    <Button text="🔍" style="-fx-background-color: #548CA8; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <FlowPane fx:id="medicineContainer" hgap="20" vgap="20" prefWrapLength="800">
                        <!-- Medicine Cards will be injected here -->
                    </FlowPane>
                </ScrollPane>
            </VBox>

            <!-- Right Side: Shopping Cart -->
            <VBox spacing="20" minWidth="450" maxWidth="450" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                
                <Label text="Current Order" style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #334257;"/>
                
                <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
                    <columns>
                        <TableColumn fx:id="itemCol" text="Item" prefWidth="180"/>
                        <TableColumn fx:id="qtyCol" text="Qty" prefWidth="80"/>
                        <TableColumn fx:id="priceCol" text="Price" prefWidth="100"/>
                        <TableColumn fx:id="actionCol" text="" prefWidth="60"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <VBox spacing="15" style="-fx-padding: 20 0 0 0; -fx-border-color: #EEEEEE; -fx-border-width: 1 0 0 0;">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Patient Name" style="-fx-text-fill: #6C757D; -fx-font-weight: 600;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="patientNameField" promptText="Walk-in Patient" style="-fx-pref-width: 200; -fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 5;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Subtotal" style="-fx-text-fill: #6C757D; -fx-font-weight: 600;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="subtotalLabel" text="\$0.00" style="-fx-font-weight: 800; -fx-text-fill: #334257;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Discount" style="-fx-text-fill: #6C757D; -fx-font-weight: 600;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="discountField" promptText="0.00" style="-fx-pref-width: 80; -fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 5; -fx-alignment: CENTER_RIGHT;"/>
                    </HBox>
                    <Separator/>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Total Payable" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #334257;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalLabel" text="\$0.00" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #548CA8;"/>
                    </HBox>
                </VBox>

                <Button text="Complete Sale" onAction="#handleCompleteSale" maxWidth="Infinity" style="-fx-background-color: #548CA8; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 800; -fx-padding: 18; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(84, 140, 168, 0.4), 10, 0, 0, 5);"/>
                <Button text="Clear Order" onAction="#handleClearOrder" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #6C757D; -fx-font-weight: 600; -fx-cursor: hand;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
