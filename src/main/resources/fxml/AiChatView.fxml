<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AiChatController" prefHeight="600.0" prefWidth="450.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #334257; -fx-padding: 15 20;">
        <Label text="🤖 MediCore AI Assistant" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Chat Area -->
    <ScrollPane fx:id="chatScrollPane" VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox fx:id="chatContainer" spacing="15" style="-fx-padding: 20; -fx-background-color: white;">
            <!-- Messages will be injected here dynamically -->
        </VBox>
    </ScrollPane>

    <!-- Input Area -->
    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-width: 1 0 0 0;">
        <TextField fx:id="messageInput" promptText="اسأل أي شيء عن العيادة..." HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #D1D1D1; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 15; -fx-font-size: 14px;" onAction="#handleSendMessage"/>
        <Button text="إرسال" onAction="#handleSendMessage" style="-fx-background-color: #548CA8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 20; -fx-cursor: hand;"/>
    </HBox>
</VBox>
