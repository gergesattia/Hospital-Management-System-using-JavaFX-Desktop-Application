<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PharmacyDashboardController" style="-fx-background-color: #EEEEEE;">
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 15 30; -fx-alignment: CENTER_LEFT; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4); -fx-border-color: #D1D1D1; -fx-border-width: 0 0 1 0;">
            <Label text="Pharmacy" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Sign Out" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #548CA8; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: #548CA8; -fx-border-width: 1.5; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>
    <left>
        <VBox style="-fx-background-color: #334257; -fx-padding: 30 15; -fx-spacing: 12; -fx-pref-width: 260;">
            <Label text="MEDICORE" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800; -fx-padding: 0 0 20 5;"/>
            <Button text="💊  Prescriptions" onAction="#showPrescriptions" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="📦  Inventory" onAction="#showInventory" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="💰  POS" onAction="#showPos" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="📊  Sales History" onAction="#showSales" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
            <Button text="🏭  Suppliers" onAction="#showSuppliers" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <VBox style="-fx-padding: 30;" spacing="20">

            <!-- Pending Prescriptions Card -->
            <VBox VBox.vgrow="ALWAYS" spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Pending Prescriptions" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <TextField fx:id="searchField" promptText="Search patient or medicine..." prefWidth="280" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8;"/>
                    <Button text="🔄" onAction="#loadPending" style="-fx-background-color: transparent; -fx-border-color: #548CA8; -fx-text-fill: #548CA8; -fx-padding: 5 10; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="pendingTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="idCol" text="Ref #" prefWidth="70"/>
                        <TableColumn fx:id="patientCol" text="Patient" prefWidth="180"/>
                        <TableColumn fx:id="medicineCol" text="Medicine" prefWidth="160"/>
                        <TableColumn fx:id="dosageCol" text="Dosage" prefWidth="100"/>
                        <TableColumn fx:id="freqCol" text="Frequency" prefWidth="130"/>
                        <TableColumn fx:id="durationCol" text="Days" prefWidth="60"/>
                        <TableColumn fx:id="doctorCol" text="Doctor" prefWidth="160"/>
                        <TableColumn fx:id="dateCol" text="Prescribed" prefWidth="140"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label fx:id="stockLabel" text="" style="-fx-text-fill: #476072; -fx-font-weight: 600;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="✅  Dispense Selected" onAction="#handleDispense" style="-fx-background-color: #548CA8; -fx-text-fill: white; -fx-font-weight: 800; -fx-padding: 12 25; -fx-background-radius: 10; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Dispensed History Card -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;" prefHeight="250">
                <Label text="Dispensed History" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;"/>
                <TableView fx:id="dispensedTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="dRefCol" text="Ref #" prefWidth="70"/>
                        <TableColumn fx:id="dPatientCol" text="Patient" prefWidth="200"/>
                        <TableColumn fx:id="dMedCol" text="Medicine" prefWidth="180"/>
                        <TableColumn fx:id="dByCol" text="Dispensed By" prefWidth="160"/>
                        <TableColumn fx:id="dAtCol" text="Dispensed At" prefWidth="160"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
