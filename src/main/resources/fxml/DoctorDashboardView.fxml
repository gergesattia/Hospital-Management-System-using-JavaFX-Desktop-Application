<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DoctorDashboardController" style="-fx-background-color: #EEEEEE;">
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 15 30; -fx-alignment: CENTER_LEFT; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4); -fx-border-color: #D1D1D1; -fx-border-width: 0 0 1 0;">
            <Label text="Doctor Workspace" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Sign Out" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #548CA8; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: #548CA8; -fx-border-width: 1.5; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>
    <left>
        <VBox style="-fx-background-color: #334257; -fx-padding: 30 15; -fx-spacing: 12; -fx-pref-width: 260;">
            <Label text="MEDICORE" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800; -fx-padding: 0 0 10 5;"/>
            <Label fx:id="waitListLabel" text="Patients Waiting: 0" style="-fx-text-fill: #ADB5BD; -fx-font-size: 13px; -fx-font-weight: 600; -fx-padding: 0 0 20 5;"/>
            <Button text="👤  Current Patient" onAction="#showCurrentPatient" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="📜  Patient History" onAction="#showHistory" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <StackPane style="-fx-padding: 30;">
            <!-- Empty State Placeholder (Visible when no patients) -->
            <VBox fx:id="emptyStateBox" alignment="CENTER" spacing="20" visible="false" managed="false">
                <StackPane alignment="CENTER">
                    <Circle radius="70" fill="#548CA8" opacity="0.07"/>
                    <Label text="🏥" style="-fx-font-size: 64px;"/>
                </StackPane>
                <VBox alignment="CENTER" spacing="8">
                    <Label text="No Patients Waiting" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #334257;"/>
                    <Label text="Waiting for new patients to be assigned to you..." style="-fx-font-size: 14px; -fx-text-fill: #6C757D;"/>
                </VBox>
            </VBox>

            <!-- Active Patient Workspace (shown when a patient is loaded) -->
            <HBox spacing="30">
                <!-- Left Side: Patient Info Card -->
                <VBox fx:id="patientInfoBox" spacing="20" minWidth="300" maxWidth="300" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                    <VBox alignment="CENTER" spacing="10">
                        <StackPane>
                            <Circle radius="40" fill="#548CA8" opacity="0.1"/>
                            <Label text="👤" style="-fx-font-size: 32px;"/>
                        </StackPane>
                        <Label fx:id="nameLabel" text="Patient Name" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;"/>
                    </VBox>
                    <Separator/>
                    <VBox spacing="15">
                        <VBox spacing="5">
                            <Label text="Age" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <Label fx:id="ageLabel" text="-" style="-fx-font-size: 15px; -fx-font-weight: 600;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Phone Number" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <Label fx:id="phoneLabel" text="-" style="-fx-font-size: 15px; -fx-font-weight: 600;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Priority Level" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <Label fx:id="criticalityLabel" text="-" style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #E71D36;"/>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Right Side: Treatment Workspace -->
                <VBox fx:id="treatmentBox" HBox.hgrow="ALWAYS" spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                    <Label text="Diagnosis &amp; Clinical Notes" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;"/>
                    <TextArea fx:id="diagnosisArea" promptText="Describe diagnosis..." VBox.vgrow="ALWAYS" wrapText="true" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                    <Separator/>
                    <Label text="Prescription Details" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;"/>
                    <GridPane hgap="15" vgap="15">
                        <columnConstraints><ColumnConstraints hgrow="ALWAYS"/><ColumnConstraints prefWidth="120"/></columnConstraints>
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Medicine Name" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="medicineField" promptText="Search medicine..." style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Dosage" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="dosageField" promptText="500mg" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Frequency" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="frequencyField" promptText="2 times daily" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Days" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="durationField" promptText="7" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                    </GridPane>
                    <VBox spacing="8">
                        <Label text="Special Instructions" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                        <TextArea fx:id="instructionsArea" promptText="Additional notes..." prefHeight="80" wrapText="true" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                    </VBox>
                    <HBox spacing="15" alignment="CENTER_RIGHT">
                        <Button text="Clear" style="-fx-background-color: white; -fx-text-fill: #476072; -fx-border-color: #D1D1D1; -fx-border-width: 1.5; -fx-padding: 12 25; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: 600;"/>
                        <Button text="Complete Appointment" onAction="#handleComplete" style="-fx-background-color: #548CA8; -fx-text-fill: white; -fx-font-weight: 800; -fx-padding: 12 25; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </HBox>
        </StackPane>
    </center>
</BorderPane>
