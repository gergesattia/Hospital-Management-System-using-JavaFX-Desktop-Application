<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReceptionistDashboardController" style="-fx-background-color: #EEEEEE;">
    <top>
        <HBox style="-fx-background-color: white; -fx-padding: 15 30; -fx-alignment: CENTER_LEFT; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4); -fx-border-color: #D1D1D1; -fx-border-width: 0 0 1 0;">
            <Label text="Reception &amp; Registration" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Sign Out" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #548CA8; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: #548CA8; -fx-border-width: 1.5; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>
    <left>
        <VBox style="-fx-background-color: #334257; -fx-padding: 30 15; -fx-spacing: 12; -fx-pref-width: 260;">
            <Label text="MEDICORE" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800; -fx-padding: 0 0 20 5;"/>
            <Button text="📝  Registration" onAction="#showManagePatients" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 600; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="📋  Prescriptions" onAction="#showPrescriptions" style="-fx-background-color: transparent; -fx-text-fill: #ADB5BD; -fx-font-size: 15px; -fx-font-weight: 500; -fx-alignment: CENTER_LEFT; -fx-padding: 12 25; -fx-max-width: 240; -fx-pref-width: 240; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <HBox style="-fx-padding: 30;" spacing="30">
            <!-- Left Side: Registration Form -->
            <VBox spacing="20" minWidth="400" maxWidth="400" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                <VBox spacing="5">
                    <Label text="New Registration" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;"/>
                    <Label text="Enter patient information below" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                </VBox>
                
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <VBox spacing="15">
                        <VBox spacing="5">
                            <Label text="Full Name" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="fullNameField" promptText="Enter full name" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="National ID (SSN)" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="ssnField" promptText="Enter ID number" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Phone Number" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="phoneField" promptText="Enter phone" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Address" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="addressField" promptText="Enter address" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Email Address" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <TextField fx:id="emailField" promptText="patient@example.com" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;"/>
                        </VBox>
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Birth Date" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                                <DatePicker fx:id="birthDatePicker" maxWidth="Infinity" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Gender" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                                <ComboBox fx:id="genderBox" maxWidth="Infinity" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;"/>
                            </VBox>
                        </HBox>
                        <VBox spacing="5">
                            <Label text="Department / Specialty" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <ComboBox fx:id="specialtyBox" maxWidth="Infinity" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Priority Level" style="-fx-text-fill: #476072; -fx-font-weight: 600;"/>
                            <ComboBox fx:id="priorityBox" maxWidth="Infinity" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
                <Button text="Add Patient to Queue" onAction="#handleAdd" maxWidth="Infinity" style="-fx-background-color: #548CA8; -fx-text-fill: white; -fx-font-weight: 800; -fx-padding: 15; -fx-background-radius: 10; -fx-cursor: hand;"/>
            </VBox>

            <!-- Right Side: Recent Patients Table -->
            <VBox HBox.hgrow="ALWAYS" spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8); -fx-border-color: #D1D1D1; -fx-border-width: 1;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Patient Queue Overview" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334257;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <TextField fx:id="searchField" promptText="Search queue..." prefWidth="200" style="-fx-background-color: #F8F9FE; -fx-border-color: #D1D1D1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8;"/>
                    <Button text="🔄" onAction="#loadPatients" style="-fx-background-color: transparent; -fx-border-color: #548CA8; -fx-text-fill: #548CA8; -fx-padding: 5 10; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
                <TableView fx:id="patientsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="nameCol" text="Full Name" prefWidth="180"/>
                        <TableColumn fx:id="ssnCol" text="National ID" prefWidth="120"/>
                        <TableColumn fx:id="phoneCol" text="Phone" prefWidth="120"/>
                        <TableColumn fx:id="emailCol" text="Email" prefWidth="160"/>
                        <TableColumn fx:id="genderCol" text="Gender" prefWidth="80"/>
                        <TableColumn fx:id="birthDateCol" text="Birth Date" prefWidth="100"/>
                        <TableColumn fx:id="addressCol" text="Address" prefWidth="140"/>
                        <TableColumn fx:id="priorityCol" text="Priority" prefWidth="80"/>
                        <TableColumn fx:id="dateCol" text="Date Added" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </HBox>
    </center>
</BorderPane>


